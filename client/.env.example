# Azure AI Foundry settings used by remote_client.py
PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project-name>
MODEL_DEPLOYMENT_NAME=<your-model-deployment-name>

# Remote MCP server settings used by remote_client.py
FUNCTION_APP_NAME=<your-function-app-name>
MCP_EXTENSION_KEY=<your-mcp-extension-system-key>

# Optional override for the full MCP endpoint URL
# MCP_SERVER_URL=https://<your-function-app-name>.azurewebsites.net/runtime/webhooks/mcp
